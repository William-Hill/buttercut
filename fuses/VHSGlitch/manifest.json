{
  "name": "VHSGlitch",
  "version": "1.0.0",
  "description": "VHS-like glitch with scanline and vertical tear controls.",
  "tested_on_resolve": "20.2.3",
  "params": [
    { "name": "intensity", "type": "number", "default": 0.5, "range": [0.0, 1.0] },
